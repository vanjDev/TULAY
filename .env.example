# Copy to `.env` and restart the app after editing.

TULAY_SECRET_KEY=change-me-to-a-long-random-secret
TULAY_ADMIN_PASSWORD=tulay-admin

# Web application OAuth client ID from Google Cloud.
# Authorized JavaScript origins for local dev:
# - http://127.0.0.1:5123
# - http://127.0.0.1:5173
GOOGLE_CLIENT_ID=
